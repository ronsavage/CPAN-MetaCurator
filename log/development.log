[2026-05-02 09:41:28.97634] [526998] [debug] 	use Cpanel::JSON::XS::Type;
[2026-05-02 09:41:28.97636] [526998] [debug] 	my $struct = {Parts => [{PartNumber => "1",
[2026-05-02 09:41:28.97637] [526998] [debug] 	ETag => "46f438ba2afd8d6dc03958b867a349b1"},
[2026-05-02 09:41:28.97639] [526998] [debug] 	{ETag => "7b1e03e9ed7bb49d907e5a2d25b89159",
[2026-05-02 09:41:28.97640] [526998] [debug] 	PartNumber => "2"},
[2026-05-02 09:41:28.97641] [526998] [debug] 	{ETag => "30c23faad792c9b7c4b05356305cb6b0",
[2026-05-02 09:41:28.97643] [526998] [debug] 	PartNumber => "3"},
[2026-05-02 09:41:28.97644] [526998] [debug] 	{ETag => "979174e5353386a75d8e36d223d22ea2",
[2026-05-02 09:41:28.97646] [526998] [debug] 	PartNumber => "4"},
[2026-05-02 09:41:28.97647] [526998] [debug] 	{PartNumber => "5",
[2026-05-02 09:41:28.97649] [526998] [debug] 	ETag => "ee93774d0a2ec9c27fae6a4fb3496804"},
[2026-05-02 09:41:28.97650] [526998] [debug] 	{PartNumber => "6",
[2026-05-02 09:41:28.97652] [526998] [debug] 	ETag => "9a2c5a1abe6869f370b07d76c270e569"}
[2026-05-02 09:41:28.97653] [526998] [debug] 	]};
[2026-05-02 09:41:28.97655] [526998] [debug] 	print encode_json($struct,
[2026-05-02 09:41:28.97656] [526998] [debug] 	{Parts => json_type_arrayof({
[2026-05-02 09:41:28.97658] [526998] [debug] 	PartNumber => JSON_TYPE_INT,
