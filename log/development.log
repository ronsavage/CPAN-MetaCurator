[2026-05-02 09:41:28.97668] [526998] [debug] 	{"PartNumber":5,"ETag":"ee93774d0a2ec9c27fae6a4fb3496804"},
[2026-05-02 09:41:28.97670] [526998] [debug] 	{"PartNumber":6,"ETag":"9a2c5a1abe6869f370b07d76c270e569"}]}
