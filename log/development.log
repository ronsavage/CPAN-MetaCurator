[2026-05-02 09:41:27.18236] [526998] [debug] 	use warnings;
[2026-05-02 09:41:27.18238] [526998] [debug] 	use File::LocalizeNewlines;
[2026-05-02 09:41:27.18239] [526998] [debug] 	# ---------------------
